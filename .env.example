# ── Django backend ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip,yourdomain.com

# ── Database (used by docker-compose postgres service) ──────────
POSTGRES_DB=igatpuri_db
POSTGRES_USER=igatpuri_user
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgres://igatpuri_user:change-this-db-password@db:5432/igatpuri_db

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-this-jwt-secret

# ── Razorpay (optional — leave blank to use manual razorpay.me link) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Frontend build args (baked in at docker build time) ─────────
# When deployed behind nginx on port 80, the API is at /api (same origin).
NEXT_PUBLIC_API_BASE_URL=/api
VITE_API_BASE_URL=/api

# ── Docker ──────────────────────────────────────────────────────
APP_PORT=80
